{
  "protocolVersion": "superspec.protocol/v1.0.0",
  "commands": {
    "next": {
      "request": {
        "change": "string",
        "owner": "string (optional)"
      },
      "response": {
        "state": "ready | blocked | done",
        "action": "object | null"
      },
      "errors": ["invalid_expression", "invalid_action_payload"]
    },
    "complete": {
      "request": {
        "change": "string",
        "actionId": "string",
        "outputJson": {
          "type": "object",
          "recommendedFields": {
            "ok": "boolean",
            "executor": "script | skill | human",
            "actionId": "string",
            "summary": "string (optional)",
            "outputs": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "fail": {
      "request": {
        "change": "string",
        "actionId": "string",
        "errorJson": {
          "type": "object",
          "recommendedFields": {
            "code": "string",
            "message": "string",
            "executor": "script | skill | human",
            "details": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "status": {
      "request": {
        "change": "string",
        "debug": "boolean (optional)",
        "full": "boolean (optional)"
      },
      "response": {
        "changeName": "string",
        "status": "running | success | failed",
        "progress": {
          "total": "integer",
          "done": "integer",
          "failed": "integer",
          "running": "integer",
          "remaining": "integer"
        }
      }
    }
  },
  "actionPayload": {
    "script": {
      "executor": "script",
      "script_command": "string",
      "inputs": "object (optional)",
      "prompt": "string"
    },
    "skill": {
      "executor": "skill",
      "skillName": "string",
      "inputs": "object (optional)",
      "prompt": "string"
    },
    "human": {
      "executor": "human",
      "human": {
        "instruction": "string",
        "approveLabel": "string (optional)",
        "rejectLabel": "string (optional)"
      },
      "inputs": "object (optional)",
      "prompt": "string"
    },
    "runtimeExpressionResolution": [
      "executor",
      "script",
      "skill",
      "prompt",
      "human.instruction",
      "human.approveLabel",
      "human.rejectLabel",
      "inputs (recursive)"
    ],
    "runtimeExpressionNotes": [
      "No generic recursive runtime resolver for arbitrary action fields",
      "Only the listed fields are expanded in next-action payload generation",
      "When action.prompt is set, payload.prompt uses rendered action.prompt for all executors",
      "inputs remains input-definition data and is not used as prompt override source"
    ]
  },
  "removed": [
    "plan run command",
    "legacy run-state storage under run-state.json and runs/<run-id>/"
  ]
}

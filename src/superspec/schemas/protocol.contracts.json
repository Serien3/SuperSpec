{
  "protocolVersion": "superspec.protocol/v0.5.0",
  "commands": {
    "next": {
      "request": {
        "change": "string",
        "owner": "string (optional)",
        "debug": "boolean (optional)"
      },
      "response": {
        "state": "ready | blocked | done",
        "changeName": "string",
        "action": "object | null"
      },
      "errors": ["invalid_expression", "invalid_action_payload"]
    },
    "complete": {
      "request": {
        "change": "string",
        "actionId": "string",
        "outputJson": {
          "type": "object",
          "recommendedFields": {
            "ok": "boolean",
            "executor": "script | skill | human",
            "actionId": "string",
            "summary": "string (optional)",
            "outputs": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "fail": {
      "request": {
        "change": "string",
        "actionId": "string",
        "errorJson": {
          "type": "object",
          "recommendedFields": {
            "code": "string",
            "message": "string",
            "executor": "script | skill | human",
            "details": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "status": {
      "request": {
        "change": "string",
        "debug": "boolean (optional)",
        "full": "boolean (optional)",
        "retry": "boolean (optional)"
      },
      "response": {
        "status": "running | success | failed",
        "progress": {
          "total": "integer",
          "done": "integer",
          "failed": "integer",
          "running": "integer",
          "remaining": "integer"
        },
        "lastFailure": "object | null",
        "actions": "array",
        "retry": {
          "scheduledCount": "integer",
          "nextWakeAt": "string | null (ISO timestamp)",
          "nextWakeInSec": "integer | null",
          "scheduled": "array of {actionId, attempts, nextEligibleAt, waitSec, lastError?}"
        },
        "actionStatusValues": "PENDING | READY | RUNNING | SUCCESS | FAILED",
        "contracts": "object (only when debug=true)",
        "notes": [
          "Default status JSON returns compact actions unless --full is provided",
          "--retry returns retry-focused payload and omits actions array"
        ]
      }
    }
  },
  "actionPayload": {
    "script": {
      "executor": "script",
      "script_command": "string",
      "prompt": "string"
    },
    "skill": {
      "executor": "skill",
      "skillName": "string",
      "prompt": "string",
      "debug": {
        "renderedPrompt": "string (only when debug=true)"
      }
    },
    "human": {
      "executor": "human",
      "human": {
        "instruction": "string",
        "approveLabel": "string (optional)",
        "rejectLabel": "string (optional)"
      },
      "prompt": "string"
    },
    "runtimeExpressionResolution": [
      "executor",
      "script",
      "skill",
      "human.instruction",
      "human.approveLabel",
      "human.rejectLabel",
      "inputs.prompt"
    ],
    "runtimeExpressionNotes": [
      "No generic recursive runtime resolver for arbitrary action fields",
      "Only the listed fields are expanded in next-action payload generation"
    ]
  },
  "removed": [
    "plan run command",
    "legacy run-state storage under run-state.json and runs/<run-id>/"
  ]
}

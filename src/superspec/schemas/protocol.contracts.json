{
  "protocolVersion": "superspec.protocol/v1.2.0",
  "commands": {
    "next": {
      "request": {
        "change": "string",
        "owner": "string (optional)"
      },
      "response": {
        "change": "string",
        "goal": "string | null",
        "state": "ready | blocked | done",
        "step": "object | null"
      },
      "errors": ["invalid_step_payload"]
    },
    "stepComplete": {
      "request": {
        "change": "string",
        "stepId": "string"
      },
      "errors": ["unknown_step", "invalid_state"]
    },
    "stepFail": {
      "request": {
        "change": "string",
        "stepId": "string"
      },
      "errors": ["unknown_step", "invalid_state"]
    },
    "status": {
      "request": {
        "change": "string",
        "debug": "boolean (optional)",
        "full": "boolean (optional)"
      },
      "response": {
        "changeName": "string",
        "status": "running | success | failed",
        "progress": {
          "total": "integer",
          "done": "integer",
          "failed": "integer",
          "running": "integer",
          "remaining": "integer"
        }
      }
    }
  },
  "stepPayload": {
    "script": {
      "script_command": "string",
      "prompt": "string"
    },
    "skill": {
      "skillName": "string",
      "prompt": "string"
    },
    "human": {
      "option": {
        "approveLabel": "string",
        "rejectLabel": "string"
      },
      "prompt": "string"
    },
    "runtimeExpressionNotes": [
      "Runtime payload generation treats ${...} strings as literal values",
      "When step.prompt is set, payload.prompt uses step.prompt for all executors"
    ]
  },
  "removed": [
    "legacy run command",
    "legacy run-state storage under run-state.json and runs/<run-id>/"
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superspec.dev/schemas/workflow-v1.json",
  "title": "SuperSpec Workflow Schema",
  "type": "object",
  "required": [
    "workflowId",
    "version",
    "actions"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "variables": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "executor"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "when": {
            "type": "string"
          },
          "executor": {
            "enum": [
              "skill",
              "script",
              "human"
            ]
          },
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "script": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string"
          },
          "human": {
            "type": "object",
            "properties": {
              "instruction": {
                "type": "string",
                "minLength": 1
              },
              "approveLabel": {
                "type": "string",
                "minLength": 1
              },
              "rejectLabel": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "instruction"
            ],
            "additionalProperties": true
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true
          },
          "outputs": {
            "type": "object",
            "additionalProperties": true
          },
          "approval": {
            "type": "object",
            "properties": {
              "required": {
                "type": "boolean"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "executor": {
                  "const": "skill"
                }
              }
            },
            "then": {
              "required": [
                "skill"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "script"
                    ]
                  },
                  {
                    "required": [
                      "human"
                    ]
                  }
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "executor": {
                  "const": "script"
                }
              }
            },
            "then": {
              "required": [
                "script"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "skill"
                    ]
                  },
                  {
                    "required": [
                      "human"
                    ]
                  }
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "executor": {
                  "const": "human"
                }
              }
            },
            "then": {
              "required": [
                "human"
              ],
              "not": {
                "anyOf": [
                  {
                    "required": [
                      "skill"
                    ]
                  },
                  {
                    "required": [
                      "script"
                    ]
                  }
                ]
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

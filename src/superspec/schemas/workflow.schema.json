{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superspec.dev/schemas/workflow-v1.json",
  "title": "SuperSpec Workflow Schema",
  "type": "object",
  "required": [
    "workflowId",
    "version",
    "actions"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "variables": {
      "type": "object",
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "properties": {
        "executor": {
          "enum": [
            "skill",
            "script"
          ]
        },
        "onFail": {
          "enum": [
            "stop",
            "continue"
          ]
        },
        "retry": {
          "type": "object",
          "properties": {
            "maxAttempts": {
              "type": "integer",
              "minimum": 0
            },
            "intervalSec": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "when": {
            "type": "string"
          },
          "executor": {
            "enum": [
              "skill",
              "script"
            ]
          },
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "script": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true
          },
          "outputs": {
            "type": "object",
            "additionalProperties": true
          },
          "defaults": {
            "type": "object",
            "properties": {
              "executor": {
                "enum": [
                  "skill",
                  "script"
                ]
              },
              "onFail": {
                "enum": [
                  "stop",
                  "continue"
                ]
              }
            },
            "additionalProperties": false
          },
          "retry": {
            "type": "object",
            "properties": {
              "maxAttempts": {
                "type": "integer",
                "minimum": 0
              },
              "intervalSec": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "onFail": {
            "enum": [
              "stop",
              "continue"
            ]
          },
          "approval": {
            "type": "object",
            "properties": {
              "required": {
                "type": "boolean"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

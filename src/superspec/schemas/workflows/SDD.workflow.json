{
  "workflowId": "SDD",
  "version": "1.0.0",
  "description": "Default spec-driven development workflow",
  "title": "Main delivery plan",
  "goal": "Execute this change in a single-agent serial loop",
  "actions": [
    {
      "id": "a1",
      "type": "proposal",
      "executor": "skill",
      "skill": "openspec-continue-change"
    },
    {
      "id": "a2",
      "type": "proposal.review",
      "dependsOn": [
        "a1"
      ],
      "executor": "human",
      "human": {
        "instruction": "Please review openspec/changes/${context.changeName}/proposal.md and approve or reject before continuing.",
        "approveLabel": "Approve proposal",
        "rejectLabel": "Request changes"
      }
    },
    {
      "id": "a3",
      "type": "proposal",
      "dependsOn": [
        "a2"
      ],
      "executor": "skill",
      "skill": "openspec-continue-change"
    },
    {
      "id": "a4",
      "type": "openspec.apply",
      "dependsOn": [
        "a3"
      ],
      "executor": "skill",
      "skill": "openspec-apply-change"
    },
    {
      "id": "a5",
      "type": "openspec.verify",
      "dependsOn": [
        "a4"
      ],
      "executor": "skill",
      "skill": "openspec-verify-change"
    }
  ]
}

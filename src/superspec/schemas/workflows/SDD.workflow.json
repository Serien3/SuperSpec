{
  "workflowId": "SDD",
  "version": "1.0.0",
  "description": "Default spec-driven development workflow",
  "title": "Main delivery plan",
  "goal": "Execute this change in a single-agent serial loop",
  "defaults": {
    "executor": "skill",
    "onFail": "stop"
  },
  "actions": [
    {
      "id": "a1",
      "type": "using-worktree",
      "executor": "script",
      "script": "cd \"$(python3 -m superspec.scripts.worktree_create --slug \"${context.changeName}\" --print-worktree-path)\" && pwd"
    },
    {
      "id": "a2",
      "type": "proposal+specs+design+tasks",
      "dependsOn": [
        "a1"
      ],
      "skill": "openspec-ff-change"
    },
    {
      "id": "a3",
      "type": "openspec.apply",
      "dependsOn": [
        "a2"
      ],
      "skill": "openspec-apply-change"
    },
    {
      "id": "a4",
      "type": "openspec.verify",
      "dependsOn": [
        "a3"
      ],
      "skill": "openspec-verify-change"
    }
  ]
}
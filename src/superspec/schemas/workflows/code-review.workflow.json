{
    "workflowId": "code-review",
    "version": "1.0.0",
    "description": "Workflow for requesting and receiving code reviews as part of the spec-driven development process",
    "steps": [
        {
            "id": "a1",
            "description": "request-code-review",
            "executor": "skill",
            "skill": "requesting-code-review"
        },
        {
            "id": "a2",
            "description": "proposal.review",
            "dependsOn": [
                "a1"
            ],
            "executor": "human",
            "human": {
                "instruction": "Please review superspec/changes/${context.changeName}/proposal.md and approve or reject before continuing."
            }
        },
        {
            "id": "a3",
            "description": "specs&design&tasks",
            "dependsOn": [
                "a2"
            ],
            "executor": "skill",
            "skill": "openspec-ff-change"
        },
        {
            "id": "a4",
            "description": "openspec.apply",
            "dependsOn": [
                "a3"
            ],
            "executor": "skill",
            "skill": "openspec-apply-change"
        },
        {
            "id": "a5",
            "description": "code-review.request",
            "dependsOn": [
                "a4"
            ],
            "executor": "skill",
            "skill": "requesting-code-review"
        },
        {
            "id": "a6",
            "description": "code-review.receive",
            "dependsOn": [
                "a5"
            ],
            "executor": "skill",
            "skill": "receiving-code-review"
        },
        {
            "id": "a7",
            "description": "openspec.verify",
            "dependsOn": [
                "a6"
            ],
            "executor": "skill",
            "skill": "openspec-verify-change"
        }
    ]
}

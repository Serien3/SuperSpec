{
    "workflowId": "code-review",
    "version": "1.0.0",
    "description": "Workflow for requesting and receiving code reviews as part of the spec-driven development process",
    "title": "Code review process",
    "goal": "Ensure that code changes are reviewed and approved by peers before being merged into the main codebase",
    "actions": [
        {
            "id": "a1",
            "type": "request-code-review",
            "executor": "skill",
            "skill": "requesting-code-review",
            "inputs": {
                "BASE_SHA": "${context.BASE_SHA}"
            }
        },
        {
            "id": "a2",
            "type": "proposal.review",
            "dependsOn": [
                "a1"
            ],
            "executor": "human",
            "human": {
                "instruction": "Please review superspec/changes/${context.changeName}/proposal.md and approve or reject before continuing.",
                "approveLabel": "Approve proposal",
                "rejectLabel": "Request changes"
            }
        },
        {
            "id": "a3",
            "type": "specs&design&tasks",
            "dependsOn": [
                "a2"
            ],
            "executor": "skill",
            "skill": "openspec-ff-change"
        },
        {
            "id": "a4",
            "type": "openspec.apply",
            "dependsOn": [
                "a3"
            ],
            "executor": "skill",
            "skill": "openspec-apply-change"
        },
        {
            "id": "a5",
            "type": "code-review.request",
            "dependsOn": [
                "a4"
            ],
            "executor": "skill",
            "skill": "requesting-code-review"
        },
        {
            "id": "a6",
            "type": "code-review.receive",
            "dependsOn": [
                "a5"
            ],
            "executor": "skill",
            "skill": "receiving-code-review"
        },
        {
            "id": "a7",
            "type": "openspec.verify",
            "dependsOn": [
                "a6"
            ],
            "executor": "skill",
            "skill": "openspec-verify-change"
        }
    ]
}

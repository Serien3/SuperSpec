{
    "workflowId": "code-review",
    "version": "1.1.0",
    "description": "Workflow for requesting and receiving code reviews as part of the spec-driven development process",
    "steps": [
        {
            "id": "a1",
            "description": "request-code-review",
            "executor": "skill",
            "skill": "requesting-code-review"
        },
        {
            "id": "a2",
            "description": "report-review",
            "dependsOn": [
                "a1"
            ],
            "executor": "human",
            "prompt": "Paste the COMPLETE raw response from the code-reviewer agent to `superspec/changes/<change_name>/report.md`."
        },
        {
            "id": "a3",
            "description": "receive-code-review-and-fix",
            "dependsOn": [
                "a2"
            ],
            "executor": "skill",
            "skill": "receiving-code-review"
        },
        {
            "id": "a4",
            "description": "commit a change",
            "dependsOn": [
                "a3"
            ],
            "executor": "script",
            "script": "superspec git commit --message \"Finish a review by Agent\""
        }
    ]
}
{
  "workflowId": "spec-dev",
  "version": "1.2.0",
  "description": "Default spec-dev workflow",
  "finishPolicy": "archive",
  "steps": [
    {
      "id": "a1",
      "description": "proposal",
      "executor": "skill",
      "skill": "writing-proposal"
    },
    {
      "id": "a2",
      "description": "specs",
      "dependsOn": [
        "a1"
      ],
      "executor": "skill",
      "skill": "writing-specs"
    },
    {
      "id": "a3",
      "description": "design",
      "dependsOn": [
        "a1"
      ],
      "executor": "skill",
      "skill": "writing-design"
    },
    {
      "id": "a4",
      "description": "tasks",
      "dependsOn": [
        "a3"
      ],
      "executor": "skill",
      "skill": "writing-tasks"
    },
    {
      "id": "a5",
      "description": "human-review-specs",
      "executor": "human",
      "dependsOn": [
        "a4"
      ],
      "prompt": "Waiting for humans to review the specs and give feedback.Ask the human if they approve(\"approveLabel\") these specs. If human rejects(\"rejectLabel\") the specs and makes new requests, modify all docs in this change until the user agrees.",
      "option": {
        "approveLabel": "approve and continue",
        "rejectLabel": "Reject and modify specs"
      }
    },
    {
      "id": "a5.1",
      "description": "git-commit",
      "dependsOn": [
        "a5"
      ],
      "executor": "script",
      "script": "git add . && git commit -m 'Finish specs and prepare for excuting tasks'"
    },
    {
      "id": "a6",
      "description": "execute-change",
      "dependsOn": [
        "a5"
      ],
      "executor": "skill",
      "skill": "executing-change"
    },
    {
      "id": "a7",
      "description": "sync-specs",
      "dependsOn": [
        "a6"
      ],
      "executor": "skill",
      "skill": "sync-specs"
    },
    {
      "id": "a8",
      "description": "superspec-git",
      "dependsOn": [
        "a7"
      ],
      "executor": "script",
      "script": "superspec git commit <change-name> --summary \"<subject>\" --details \"<body>\" --next \"<next>\"",
      "prompt": "Fill in the parameters and execute the command. Specifically: `summary`- a one-sentence title that *must* begin with a verb and focus on the primary change introduced by this commit; `details`(Optional) - 2 to 6 lines explaining what this commit accomplished, which parts were affected, and the rationale behind the changes; `next`- what is planned for the next step, or what requires attention."
    }
  ]
}
{
  "protocolVersion": "superspec.protocol/v0.3",
  "commands": {
    "next": {
      "request": {
        "change": "string",
        "owner": "string (optional)",
        "debug": "boolean (optional)"
      },
      "response": {
        "state": "ready | blocked | done",
        "changeName": "string",
        "action": "object | null"
      }
    },
    "complete": {
      "request": {
        "change": "string",
        "actionId": "string",
        "resultJson": {
          "type": "object",
          "recommendedFields": {
            "ok": "boolean",
            "executor": "script | skill",
            "actionId": "string",
            "summary": "string (optional)",
            "outputs": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "fail": {
      "request": {
        "change": "string",
        "actionId": "string",
        "errorJson": {
          "type": "object",
          "recommendedFields": {
            "code": "string",
            "message": "string",
            "executor": "script | skill",
            "retryable": "boolean (optional)",
            "details": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "unknown_action", "invalid_state"]
    },
    "status": {
      "request": {
        "change": "string",
        "debug": "boolean (optional)"
      },
      "response": {
        "status": "running | success | failed",
        "progress": {
          "total": "integer",
          "done": "integer",
          "failed": "integer",
          "running": "integer",
          "remaining": "integer"
        },
        "lastFailure": "object | null",
        "actions": "array",
        "actionStatusValues": "PENDING | READY | RUNNING | SUCCESS | FAILED",
        "contracts": "object (only when debug=true)"
      }
    }
  },
  "actionPayload": {
    "script": {
      "executor": "script",
      "scriptName": "string",
      "prompt": "string"
    },
    "skill": {
      "executor": "skill",
      "skillName": "string",
      "prompt": "string",
      "debug": {
        "renderedPrompt": "string (only when debug=true)"
      }
    }
  },
  "removed": [
    "plan run command",
    "legacy run-state storage under run-state.json and runs/<run-id>/"
  ]
}

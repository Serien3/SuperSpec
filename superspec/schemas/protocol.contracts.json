{
  "protocolVersion": "superspec.protocol/v0.2",
  "commands": {
    "next": {
      "request": {
        "change": "string",
        "owner": "string (optional)",
        "leaseTtlSec": "integer (optional)",
        "debug": "boolean (optional)"
      },
      "response": {
        "state": "ready | blocked | done",
        "changeName": "string",
        "leaseId": "string (present when ready)",
        "action": "object | null",
        "instruction": "string"
      }
    },
    "complete": {
      "request": {
        "change": "string",
        "actionId": "string",
        "lease": "string",
        "resultJson": {
          "type": "object",
          "recommendedFields": {
            "ok": "boolean",
            "executor": "script | skill",
            "actionId": "string",
            "summary": "string (optional)",
            "outputs": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "invalid_lease", "unknown_action", "invalid_state"]
    },
    "fail": {
      "request": {
        "change": "string",
        "actionId": "string",
        "lease": "string",
        "errorJson": {
          "type": "object",
          "recommendedFields": {
            "code": "string",
            "message": "string",
            "executor": "script | skill",
            "retryable": "boolean (optional)",
            "details": "object (optional)"
          }
        }
      },
      "errors": ["invalid_payload", "invalid_lease", "unknown_action", "invalid_state"]
    },
    "status": {
      "request": {
        "change": "string"
      },
      "response": {
        "status": "running | success | failed",
        "progress": {
          "total": "integer",
          "done": "integer",
          "failed": "integer",
          "running": "integer",
          "remaining": "integer"
        },
        "leases": "object",
        "lastFailure": "object | null",
        "actions": "array"
      }
    }
  },
  "actionPayload": {
    "script": {
      "executor": "script",
      "script": {
        "command": "string",
        "timeoutSec": "integer"
      },
      "contextFiles": "object"
    },
    "skill": {
      "executor": "skill",
      "skill": {
        "name": "string",
        "version": "string",
        "input": "object",
        "contextFiles": "object"
      },
      "debug": {
        "renderedPrompt": "string (only when debug=true)"
      }
    }
  },
  "leaseLifecycle": {
    "tokenFormat": "lease_<action-id>_<12hex>",
    "states": ["issued", "validated", "expired", "reclaimed"],
    "fields": ["leaseId", "owner", "issuedAt", "expiresAt", "ttlSec"]
  },
  "removed": [
    "plan run command",
    "legacy run-state storage under run-state.json and runs/<run-id>/"
  ]
}

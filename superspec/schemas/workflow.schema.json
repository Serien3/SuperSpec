{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superspec.dev/schemas/workflow-v1.json",
  "title": "SuperSpec Workflow Schema",
  "type": "object",
  "required": [
    "workflowId",
    "version",
    "actions"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "variables": {
      "type": "object"
    },
    "defaults": {
      "type": "object"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object"
    },
    "plan": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

{
  "schemaVersion": "superspec.plan/v0.1",
  "planId": "main",
  "title": "Main delivery plan",
  "goal": "Complete artifacts and apply implementation for this change",
  "context": {
    "changeName": "${CHANGE_NAME}",
    "changeDir": "openspec/changes/${CHANGE_NAME}",
    "repoRoot": ".",
    "specRoot": "openspec"
  },
  "defaults": {
    "executor": "skill",
    "timeoutSec": 900,
    "onFail": "stop",
    "ifExists": "fail",
    "retry": {
      "maxAttempts": 1,
      "backoffSec": 0,
      "strategy": "fixed"
    }
  },
  "actions": [
    {
      "id": "a1",
      "type": "openspec.proposal",
      "skill": "openspec-continue-change"
    },
    {
      "id": "a2",
      "type": "openspec.specs",
      "dependsOn": ["a1"],
      "skill": "openspec-continue-change"
    },
    {
      "id": "a3",
      "type": "openspec.design",
      "dependsOn": ["a2"],
      "skill": "openspec-continue-change"
    },
    {
      "id": "a4",
      "type": "openspec.tasks",
      "dependsOn": ["a3"],
      "skill": "openspec-continue-change"
    },
    {
      "id": "a5",
      "type": "openspec.apply",
      "dependsOn": ["a4"],
      "skill": "openspec-apply-change"
    }
  ],
  "policies": {
    "allowPartialSuccess": false,
    "stopOnValidationError": true
  }
}
